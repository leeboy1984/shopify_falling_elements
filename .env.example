# Filled automatically by `shopify app dev`, or set manually for production.
# Get these from your Shopify Partner Dashboard > Apps > (your app) > Configuration.

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Comma separated. Must match shopify.app.toml [access_scopes].
SCOPES=write_products

# Public URL of the app (tunnel in dev, your host in prod). No trailing slash.
SHOPIFY_APP_URL=https://localhost:3000

# Prisma. SQLite for local dev; switch to Postgres/MySQL in production.
DATABASE_URL="file:./dev.sqlite"

# App Store handle used to build the Managed Pricing URL.
# Find it in Partner Dashboard once the listing exists (e.g. "floating-elements").
SHOPIFY_APP_HANDLE=floating-elements
