{% comment %}
  Floating Elements — app embed block.
  Merchants enable this from: Theme editor → Customize → App embeds.
  The on/off and page-targeting live in the app dashboard; this block just
  loads the renderer, which fetches the live config from the App Proxy.
{% endcomment %}

{% assign fe_config = shop.metafields.floating_elements.config.value %}
{% if block.settings.enabled and fe_config %}
  <script
    src="{{ 'floating-elements.js' | asset_url }}"
    data-config="{{ fe_config | json | escape }}"
    data-template="{{ request.page_type }}"
    data-z-index="{{ block.settings.z_index }}"
    defer></script>
{% endif %}

{% schema %}
{
  "name": "Floating Elements",
  "target": "body",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Activar efecto en la tienda",
      "default": true
    },
    {
      "type": "paragraph",
      "content": "Elige el elemento, la cantidad, la velocidad y dónde se muestra desde el panel de la aplicación Floating Elements."
    },
    {
      "type": "select",
      "id": "z_index",
      "label": "Capa (profundidad)",
      "options": [
        { "value": "2147483000", "label": "Por encima de todo" },
        { "value": "999", "label": "Por encima del contenido" },
        { "value": "1", "label": "Por debajo de menús y barras fijas" }
      ],
      "default": "2147483000",
      "info": "Baja la capa si el efecto tapa menús u otros elementos fijos."
    }
  ]
}
{% endschema %}
